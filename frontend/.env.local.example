# Override backend API URL (optional).
# Default: auto-detected (http://localhost:8000 locally,
#          https://<codespace>-8000.preview.app.github.dev in Codespaces)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Override WebSocket URL (optional).
# Default: derived from NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
