# ── Required ──
# OpenAI API key (use "demo" for no-key demo mode)
# OPENAI_API_KEY=sk-...

# ── Database ──
# SQLite (default, good for dev):
DATABASE_URL=sqlite:///./studioos.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:pass@localhost:5432/studioos

# ── API ──
CORS_ORIGINS=http://localhost:3000
# For production with custom domain:
# CORS_ORIGINS=https://app.mydomain.com

# ── LLM ──
OPENAI_MODEL=gpt-4o-mini

# ── Environment ──
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Output ──
OUTPUT_DIR=output
